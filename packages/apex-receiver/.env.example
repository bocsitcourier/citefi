# ApexContent Receiver Configuration
# Copy this file to .env and fill in your values

# Required: API key for authentication (get this from ApexContent Engine)
APEX_API_KEY=your-api-key-here

# Required: URL of the ApexContent Engine
APEX_ENGINE_URL=https://your-apex-engine.replit.app

# Required: Public URL of this website
BASE_URL=https://yoursite.com

# Optional: Server port (default: 3000)
PORT=3000

# Optional: Local storage path for media files (default: ./uploads)
STORAGE_PATH=./uploads

# Optional: Enable debug logging (default: false)
DEBUG=false
