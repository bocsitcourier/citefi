# Database (Required)
DATABASE_URL=your_postgresql_connection_string_here

# AI Services (Required)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Storage (Required for image generation)
DO_SPACES_KEY=your_digitalocean_spaces_key_here
DO_SPACES_SECRET=your_digitalocean_spaces_secret_here
DO_SPACES_ENDPOINT=your_spaces_endpoint_here
DO_SPACES_BUCKET=your_bucket_name_here

# Redis (Required for BullMQ job queue in production)
# For development: Leave as default (workers will be disabled)
# For production: Use Upstash Redis or other Redis provider
# Example: redis://default:password@your-redis-url:6379
REDIS_URL=redis://localhost:6379

# Session
SESSION_SECRET=your_session_secret_here
