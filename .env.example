# ════════════════════════════════════════════════════════════════════
# Citefi — Environment Variables
# Copy this file to .env.local and fill in your values.
# Lines starting with # are comments and are ignored.
# ════════════════════════════════════════════════════════════════════

# ── Database (Required) ───────────────────────────────────────────
# Direct connection string (used by Drizzle migrations + Neon serverless driver)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
# Pooled connection string (used by API routes for high-concurrency writes)
DATABASE_POOLED_URL=postgresql://user:password@pooler.host/dbname?sslmode=require

# ── AI Services (Required) ────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Gemini model overrides (optional — defaults to latest stable)
# GEMINI_PRO_MODEL=gemini-2.5-pro
# GEMINI_FLASH_MODEL=gemini-2.5-flash
# GEMINI_IMAGE_MODEL=gemini-2.5-flash
# GEMINI_ARTICLE_MODEL=gemini-2.5-pro
# GEMINI_CRITIQUE_MODEL=gemini-2.5-flash
# GEMINI_EXPERIMENTAL_MODEL=gemini-2.5-pro

# OpenAI model overrides (optional)
# GPT_REVIEW_MODEL=chatgpt-4o-latest
# GPT_ENHANCEMENT_MODEL=gpt-4o
# GPT_ADVANCED_MODEL=gpt-4o
# GPT_HYPERLINK_EXTRACT_MODEL=gpt-4o-mini
# GPT_HYPERLINK_CORRECTION_MODEL=gpt-4o-mini
# TTS_MODEL=tts-1-hd
# TTS_VOICE=nova
# VEO_VIDEO_MODEL=veo-2.0-generate-001

# ── Storage — Digital Ocean Spaces (Required for media) ───────────
# Create a Space at: https://cloud.digitalocean.com/spaces
# Get API keys at:   Settings → Spaces Access Keys
DO_SPACES_KEY=your_spaces_access_key_here
DO_SPACES_SECRET=your_spaces_secret_key_here
# Endpoint format: https://<region>.digitaloceanspaces.com
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_BUCKET=your-space-name-here

# ── Authentication (Required) ─────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_64_chars_minimum
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=https://yourdomain.com

# Token used to sign admin email review links
APPROVAL_TOKEN_SECRET=your_approval_token_secret_here

# Secret used to encrypt stored OAuth tokens
API_KEY_ENCRYPTION_SECRET=your_encryption_secret_here

# ── App URLs (Required in production) ────────────────────────────
APP_URL=https://yourdomain.com
NEXT_PUBLIC_APP_URL=https://yourdomain.com
PUBLIC_BASE_URL=https://yourdomain.com

# ── Email (Optional — logs to console if not set) ────────────────
# SMTP_HOST=smtp.yourmailprovider.com
# SMTP_PORT=587
# SMTP_USER=your_smtp_username
# SMTP_PASS=your_smtp_password
# SMTP_FROM=noreply@yourdomain.com

# ── Brave Search API (Required for topic research) ───────────────
BRAVE_API_KEY=your_brave_search_api_key_here

# ── Slack Notifications (Optional) ───────────────────────────────
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# ── Stripe Payments (Optional) ───────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Social Platform OAuth (Optional) ─────────────────────────────
# Facebook / Meta
# FACEBOOK_APP_ID=your_app_id
# FACEBOOK_APP_SECRET=your_app_secret
# FACEBOOK_REDIRECT_URI=https://yourdomain.com/api/auth/callback/facebook

# LinkedIn
# LINKEDIN_CLIENT_ID=your_client_id
# LINKEDIN_CLIENT_SECRET=your_client_secret
# LINKEDIN_REDIRECT_URI=https://yourdomain.com/api/auth/callback/linkedin

# TikTok
# TIKTOK_CLIENT_KEY=your_client_key
# TIKTOK_CLIENT_SECRET=your_client_secret
# TIKTOK_REDIRECT_URI=https://yourdomain.com/api/auth/callback/tiktok

# ── Google Drive Integration (Optional) ──────────────────────────
# GOOGLE_DRIVE_ENABLED=false
# GOOGLE_DRIVE_FOLDER_ID=your_folder_id
# GOOGLE_DRIVE_SERVICE_ACCOUNT_EMAIL=sa@project.iam.gserviceaccount.com
# GOOGLE_DRIVE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# ── Reddit API (Optional — for intent research) ──────────────────
# REDDIT_CLIENT_ID=your_reddit_client_id
# REDDIT_SECRET=your_reddit_secret

# ── Worker Tuning (Optional) ──────────────────────────────────────
# ARTICLE_WORKER_CONCURRENCY=3
# OPENAI_CONCURRENCY=5
# GEMINI_RATE_LIMIT=2000
# CHATGPT_REVIEW_TIMEOUT_MS=120000
# GPT_ENHANCEMENT_TIMEOUT_MS=180000

# ── Feature Flags (Optional — set to "true" to disable) ──────────
# DISABLE_CHATGPT_REVIEW=false
# DISABLE_GPT_ENHANCEMENT=false
# DISABLE_ARTICLE_CRITIQUE=false
# DISABLE_CRITIC_LOOP=false
# DISABLE_REFLEXIVE_CHECK=false
# DISABLE_WORKERS=false
