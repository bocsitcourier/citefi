modules = ["nodejs-20", "web", "postgresql-16", "python-3.11"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"
packages = ["ffmpeg", "jq", "unzip", "run", "uwhoisd"]

[deployment]
deploymentTarget = "vm"
build = ["npm", "run", "build"]
run = ["npm", "run", "start"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5904
externalPort = 3000

[env]
PORT = "5000"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[agent]
integrations = ["javascript_mem_db:1.0.0", "javascript_openai:1.0.0", "javascript_database:1.0.0", "javascript_object_storage:1.0.0"]

[userenv]

[userenv.shared]
API_KEY_ENCRYPTION_SECRET = "935772b1ebe93e7dcd18830cbeabff0af0ed73b2cd52d7e539d41e86f22a08b9"
NODE_OPTIONS = "--max-old-space-size=4096"

[objectStorage]
defaultBucketID = "replit-objstore-de84b703-ccbb-4b3d-a923-9a198c55f981"
